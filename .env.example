BB_BASE_URL=https://course.pku.edu.cn/
BB_LOGIN_URL=https://course.pku.edu.cn/webapps/bb-sso-BBLEARN/login.html
BB_COURSES_URL=https://course.pku.edu.cn/webapps/portal/execute/tabs/tabAction?tab_tab_group_id=_1_1
BB_STATE_PATH=data/storage_state.json
BB_USERNAME=
BB_PASSWORD=

DB_PATH=data/state.db
# Server酱 push (Android via WeChat):
# - Get your SENDKEY from https://sct.ftqq.com/
SERVERCHAN_SENDKEY=
POLL_LIMIT_PER_RUN=100
# Course filtering mode:
# - current: only process courses with "(xx-xx学年第N学期)" matching current term (recommended)
# - off: disable term filtering
COURSE_TERM_FILTER=current
HEADLESS=1
LOG_PATH=logs/run.log
